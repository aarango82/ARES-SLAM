<launch>
    <!-- lidar odometry -->
   <include file="$(find-pkg-share mola_lidar_odometry)/ros2-launchs/ros2-lidar-odometry.launch.py">
        <arg name="lidar_topic_name" value="/main/points"/>
        <arg name="use_state_estimator" value="False"/>
        <arg name="start_mapping_enabled" value="False"/>
        <arg name="ignore_imu_pose_from_tf" value="True"/>
        <arg name="ignore_lidar_pose_from_tf" value="True"/>
        <arg name="publish_localization_following_rep105:=False" value="False"/>
        <arg name="use_mola_gui" value="False" />
    </include>

    <node pkg="robot_localization"
        exec="ekf_node"
        name="ekf_filter_node"
        output="screen">

    <param name="map_frame" value="map"/>
    <param name="odom_frame" value="odom"/>
    <param name="base_link_frame" value="base_link"/>
    <param name="world_frame" value="odom"/>

    <param name="odom0" value="/odom"/>

    <param name="odom0_config" value="
        [true,  true,  true,
        true,  true,  true,
        true,  true,  true,
        false, false, false,
        false, false, false]"/>

    <param name="publish_tf" value="true"/>
    <param name="frequency" value="50.0"/>

    </node>
</launch>